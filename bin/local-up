#!/usr/bin/env bash
# Spin up a full-fidelity local replica of the cluster on macOS/Linux using Multipass.
# Five Ubuntu 24.04 VMs (3 servers, 2 clients), private network, real systemd.
# Then runs the same Ansible bootstrap that targets cloud nodes.
#
# Requires: multipass (`brew install --cask multipass` on macOS, snap on Linux)
#           ansible (`brew install ansible` or pipx install ansible)

set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

if ! command -v multipass >/dev/null; then
  cat <<'EOF' >&2
multipass is not installed.

Install on macOS:    brew install --cask multipass
Install on Linux:    sudo snap install multipass
EOF
  exit 1
fi

if ! command -v ansible-playbook >/dev/null; then
  cat <<'EOF' >&2
ansible-playbook is not installed.

Install on macOS:    brew install ansible
Install on Linux:    pipx install ansible
EOF
  exit 1
fi

# Defaults learned from Layer 3 testing: 1 CPU/1 GB/5 GB → not enough.
# Prometheus + Grafana + Traefik + node-exporter + whoami exhaust both disk
# and memory. With 2 CPU / 2 GB / 10 GB everything fits comfortably.
CPUS="${LOCAL_CPUS:-2}"
MEM="${LOCAL_MEM:-2G}"
DISK="${LOCAL_DISK:-10G}"
IMAGE="${LOCAL_IMAGE:-24.04}"
PREFIX="${LOCAL_PREFIX:-nomad-local}"

NODES=(
  "${PREFIX}-server-01:server"
  "${PREFIX}-server-02:server"
  "${PREFIX}-server-03:server"
  "${PREFIX}-client-01:client"
  "${PREFIX}-client-02:client"
)

# 1. Ensure SSH key exists for VM provisioning
SSH_KEY_PATH="${HOME}/.ssh/id_ed25519_nomad_local"
if [[ ! -f "$SSH_KEY_PATH" ]]; then
  echo "==> Generating SSH key at $SSH_KEY_PATH"
  ssh-keygen -t ed25519 -N "" -C "nomad-local" -f "$SSH_KEY_PATH"
fi
SSH_PUB="$(cat "${SSH_KEY_PATH}.pub")"

# 2. Render cloud-init that installs the SSH key for the ubuntu user and root
CLOUD_INIT="$(mktemp)"
cat > "$CLOUD_INIT" <<EOF
#cloud-config
ssh_authorized_keys:
  - ${SSH_PUB}
users:
  - default
  - name: root
    ssh_authorized_keys:
      - ${SSH_PUB}
disable_root: false
EOF

# 3. Launch missing VMs
for spec in "${NODES[@]}"; do
  name="${spec%%:*}"
  if multipass info "$name" >/dev/null 2>&1; then
    echo "==> $name already exists, skipping"
  else
    echo "==> Launching $name (${CPUS} cpu, ${MEM} mem, ${DISK} disk, Ubuntu ${IMAGE})"
    multipass launch "$IMAGE" --name "$name" \
      --cpus "$CPUS" --memory "$MEM" --disk "$DISK" \
      --cloud-init "$CLOUD_INIT"
  fi
done

rm -f "$CLOUD_INIT"

# 4. Build inventory hosts.ini from `multipass list`
INV_DIR="$ROOT_DIR/ansible/inventory"
mkdir -p "$INV_DIR"
INV="$INV_DIR/hosts.ini"

{
  echo "; Auto-generated by bin/local-up at $(date -u +%FT%TZ)"
  echo "[servers]"
  for spec in "${NODES[@]}"; do
    name="${spec%%:*}"
    role="${spec##*:}"
    [[ "$role" == "server" ]] || continue
    ip=$(multipass info "$name" --format json | python3 -c "import sys,json; d=json.load(sys.stdin); print(d['info']['$name']['ipv4'][0])")
    echo "$name ansible_host=$ip private_ip=$ip"
  done
  echo
  echo "[clients]"
  for spec in "${NODES[@]}"; do
    name="${spec%%:*}"
    role="${spec##*:}"
    [[ "$role" == "client" ]] || continue
    ip=$(multipass info "$name" --format json | python3 -c "import sys,json; d=json.load(sys.stdin); print(d['info']['$name']['ipv4'][0])")
    echo "$name ansible_host=$ip private_ip=$ip"
  done
  echo
  echo "[all:vars]"
  echo "ansible_user=root"
  echo "ansible_ssh_private_key_file=$SSH_KEY_PATH"
  echo "ansible_ssh_common_args='-o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null'"
} > "$INV"

echo
echo "==> Inventory written to $INV"
cat "$INV"

# 5. Local-mode group_vars override (no ACME, lower resources, no hardening that needs UFW)
LOCAL_VARS="$INV_DIR/group_vars/all_local.yml"
mkdir -p "$INV_DIR/group_vars"
cat > "$LOCAL_VARS" <<'EOF'
# Auto-generated by bin/local-up. This file overrides values in
# ansible/group_vars/all.yml when the inventory is the local Multipass one.
acme_enabled: false
traefik_domain: "cluster.local"
traefik_dashboard_host: "traefik.cluster.local"
EOF
echo "==> Local overrides at $LOCAL_VARS"

# 6. Run the bootstrap
export ANSIBLE_CONFIG="$ROOT_DIR/ansible/ansible.cfg"
export ANSIBLE_ROLES_PATH="$ROOT_DIR/ansible/roles"

echo
echo "==> Running secrets playbook"
ansible-playbook "$ROOT_DIR/ansible/playbooks/secrets.yml"

echo
echo "==> Running bootstrap playbook"
# all.yml and secrets.yml live in ansible/inventory/group_vars/ and auto-load.
# Pass only the local override via -e (file is named all_local.yml so Ansible
# won't auto-discover it; -e is the right path for overrides anyway).
ansible-playbook \
  -i "$INV" \
  -e "@$LOCAL_VARS" \
  "$ROOT_DIR/ansible/playbooks/bootstrap.yml"

echo
echo "==> Cluster is up. Add to /etc/hosts to reach Traefik:"
client_ip=$(grep -A99 '^\[clients\]' "$INV" | grep -E 'ansible_host=' | head -1 | awk -F'ansible_host=' '{print $2}' | awk '{print $1}')
echo "    $client_ip cluster.local traefik.cluster.local grafana.cluster.local"
echo
echo "Then:  curl -k https://cluster.local/whoami"
