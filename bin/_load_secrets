#!/usr/bin/env bash
# Source-only helper. Decrypts secrets/cluster.yaml (if present) via sops
# and exports VULTR_API_KEY / LINODE_TOKEN / TF_VAR_ssh_public_key when found.
# Silently no-ops if the file or sops isn't available.

set -euo pipefail

_load_secrets__file="${1:-${ROOT_DIR:?must set ROOT_DIR}/secrets/cluster.yaml}"

if [[ ! -f "$_load_secrets__file" ]]; then
  return 0 2>/dev/null || exit 0
fi

if ! command -v sops >/dev/null; then
  echo "secrets/cluster.yaml exists but 'sops' not on PATH; skipping" >&2
  return 0 2>/dev/null || exit 0
fi

_load_secrets__plain="$(sops --decrypt "$_load_secrets__file")"

_get() { printf '%s\n' "$_load_secrets__plain" | awk -v k="$1:" '$1 == k {sub(/^[^"]*"/, ""); sub(/".*$/, ""); print; exit}'; }

v="$(_get vultr_api_key || true)";        [[ -n "${v:-}" ]] && export VULTR_API_KEY="$v"
v="$(_get linode_token || true)";         [[ -n "${v:-}" ]] && export LINODE_TOKEN="$v"
v="$(_get ssh_public_key || true)";       [[ -n "${v:-}" ]] && export TF_VAR_ssh_public_key="$v"

unset _load_secrets__plain _load_secrets__file
