job "nomad-autoscaler" {
  datacenters = ["{{ nomad_datacenter }}"]
  type        = "service"

  group "autoscaler" {
    count = 1

    constraint {
      attribute = "${node.class}"
      operator  = "="
      value     = "client"
    }

    network {
      port "http" {
        static = 8080
      }
    }

    service {
      name = "nomad-autoscaler"
      port = "http"

      check {
        type     = "http"
        path     = "/v1/health"
        interval = "10s"
        timeout  = "2s"
      }
    }

    task "autoscaler" {
      driver = "docker"

      template {
        destination = "local/config.hcl"
        change_mode = "restart"
        data = <<EOH
nomad {
  address = "http://{{ '{{' }} env "attr.unique.network.ip-address" {{ '}}' }}:4646"
  token   = "{{ nomad_bootstrap_token }}"
}

apm "prometheus" {
  driver = "prometheus"
  config = {
    address = "http://{{ '{{' }} range service "prometheus" {{ '}}' }}{{ '{{' }} .Address {{ '}}' }}:{{ '{{' }} .Port {{ '}}' }}{{ '{{' }} end {{ '}}' }}"
  }
}

strategy "target-value" {
  driver = "target-value"
}

policy_eval {
  workers {
    cluster    = 10
    horizontal = 10
  }
}

telemetry {
  prometheus_metrics = true
  disable_hostname   = true
}
EOH
      }

      config {
        image = "{{ autoscaler_image }}"
        args  = ["agent", "-config=/local/config.hcl"]
        ports = ["http"]
      }

      resources {
        cpu    = 100
        memory = 128
      }
    }
  }
}
